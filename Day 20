import java.util.Scanner;
public class RowSum {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int rows = sc.nextInt();
        int cols = sc.nextInt();
        int[][] a = new int[rows][cols];
        for (int i = 0; i < rows; i++) {
            int sum = 0;
            for (int j = 0; j < cols; j++) {
                a[i][j] = sc.nextInt();
                sum += a[i][j];
            }
            System.out.println(sum);
        }
    }
}
