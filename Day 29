import java.util.Scanner;
public class StringOps {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.next();
        int choice = sc.nextInt();
        if (choice == 1) {
            System.out.println(s.length());
        } else if (choice == 2) {
            System.out.println(s.toUpperCase());
        }
    }
}
