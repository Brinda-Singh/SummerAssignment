import java.util.Scanner;
public class PerfectNumber {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int num = sc.nextInt();
        int sum = 0;

        for (int i = 1; i <= num / 2; i++) {
            if (num % i == 0) {
                sum = sum + i;
            }
        }
        
        if (sum == num && num != 0) System.out.println(num + " is a Perfect Number.");
        else System.out.println(num + " is not a Perfect Number.");
    }
}
//ques 18
import java.util.Scanner;
public class StrongNumber {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int num = sc.nextInt();
        int temp = num, sum = 0;
        
        while (temp > 0) {
            int rem = temp % 10;
            int fact = 1;

            for (int i = 1; i <= rem; i++) {
                fact = fact * i;
            }
            sum = sum + fact;
            temp = temp / 10;
        }
        
        if (sum == num) System.out.println(num + " is a Strong Number.");
        else System.out.println(num + " is not a Strong Number.");
    }
}
