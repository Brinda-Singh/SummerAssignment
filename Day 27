import java.util.Scanner;
public class StudentRecord {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String[] names = new String[3];
        int[] rolls = new int[3];
        for (int i = 0; i < 3; i++) {
            names[i] = sc.next();
            rolls[i] = sc.nextInt();
        }
        for (int i = 0; i < 3; i++) {
            System.out.println("Roll: " + rolls[i] + ", Name: " + names[i]);
        }
    }
}
