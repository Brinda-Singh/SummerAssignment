import java.util.Scanner;
public class LargestPrimeFactor {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int num = sc.nextInt();
        int maxPrime = -1;
        
        // Pehle 2 se divide karke chota karenge
        while (num % 2 == 0) {
            maxPrime = 2;
            num /= 2;
        }
        // Phir odd numbers se divide karenge
        for (int i = 3; i <= Math.sqrt(num); i += 2) {
            while (num % i == 0) {
                maxPrime = i;
                num /= i;
            }
        }
        // Agar aakhiri bacha hua number 2 se bada prime hai
        if (num > 2) maxPrime = num;
        
        System.out.println("Largest Prime Factor: " + maxPrime);
    }
}
