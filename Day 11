import java.util.Scanner;
public class FuncSum {
    public static int findSum(int a, int b) {
        return a + b;
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int x = sc.nextInt();
        int y = sc.nextInt();
        System.out.println(findSum(x, y));
    }
}
