import java.util.Scanner;
public class InventorySystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int stock = 100;
        int sold = sc.nextInt();
        if (sold <= stock) {
            stock -= sold;
            System.out.println("Sold. Stock left: " + stock);
        } else {
            System.out.println("Out of stock");
        }
    }
}
